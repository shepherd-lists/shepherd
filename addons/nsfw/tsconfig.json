{
  "compilerOptions": {
    "resolveJsonModule": true,
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "strict": true,

    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "src/**/*.ts",
    "../classifier-host/src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "infra"
  ]
}
